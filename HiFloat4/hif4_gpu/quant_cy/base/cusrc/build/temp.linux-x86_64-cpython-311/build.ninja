ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda-12.1/bin/nvcc

cflags = -pthread -B /home/wujianfeng/miniconda3/envs/vllm_omni/compiler_compat -DNDEBUG -fwrapv -O2 -Wall -fPIC -O2 -isystem /home/wujianfeng/miniconda3/envs/vllm_omni/include -fPIC -O2 -isystem /home/wujianfeng/miniconda3/envs/vllm_omni/include -fPIC -I/home/wujianfeng/miniconda3/envs/vllm_omni/lib/python3.11/site-packages/torch/include -I/home/wujianfeng/miniconda3/envs/vllm_omni/lib/python3.11/site-packages/torch/include/torch/csrc/api/include -I/usr/local/cuda-12.1/include -I/home/wujianfeng/miniconda3/envs/vllm_omni/include/python3.11 -c
post_cflags = -DTORCH_API_INCLUDE_EXTENSION_H -DTORCH_EXTENSION_NAME=lowbit_quant -std=c++17
cuda_cflags = -I/home/wujianfeng/miniconda3/envs/vllm_omni/lib/python3.11/site-packages/torch/include -I/home/wujianfeng/miniconda3/envs/vllm_omni/lib/python3.11/site-packages/torch/include/torch/csrc/api/include -I/usr/local/cuda-12.1/include -I/home/wujianfeng/miniconda3/envs/vllm_omni/include/python3.11 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -DTORCH_API_INCLUDE_EXTENSION_H -DTORCH_EXTENSION_NAME=lowbit_quant -gencode=arch=compute_80,code=compute_80 -gencode=arch=compute_80,code=sm_80 -std=c++17
cuda_dlink_post_cflags = 
sycl_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags







